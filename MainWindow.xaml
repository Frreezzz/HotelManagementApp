<Window x:Class="HotelManagementApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System zarządzania hotelem"
        Height="760"
        Width="1220"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#D8E0EC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SmallCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="MinHeight" Value="112"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#52637A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="BorderBrush" Value="#D8E0EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EAF2FF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#D8E0EC"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="24,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E3A8A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel>
                    <TextBlock Text="System zarządzania hotelem"
                               Foreground="White"
                               FontSize="32"
                               FontWeight="Bold"/>
                    <TextBlock Text="Panel recepcji hotelowej"
                               Foreground="#DBEAFE"
                               FontSize="14"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Button Content="Odśwież dane"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="130"/>
            </Grid>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding Message}"
                   Background="#E0F2FE"
                   Foreground="#075985"
                   Padding="12"
                   FontWeight="Bold"/>

        <TabControl Margin="14">
            <TabItem Header="Panel główny">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Panel główny"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,18"/>

                        <UniformGrid Columns="5" Margin="0,0,0,10">
                            <Border Style="{StaticResource SmallCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Goście" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding GuestsCount}" FontSize="34" FontWeight="Bold" Foreground="#2563EB"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SmallCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Dostępne pokoje" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding AvailableRoomsCount}" FontSize="34" FontWeight="Bold" Foreground="#16A34A"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SmallCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Aktywne rezerwacje" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding ActiveReservationsCount}" FontSize="34" FontWeight="Bold" Foreground="#EA580C"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SmallCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Pracownicy" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding EmployeesCount}" FontSize="34" FontWeight="Bold" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SmallCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Suma płatności" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding TotalPayments, StringFormat={}{0:C}}" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="0" MinHeight="280">
                                <StackPanel>
                                    <TextBlock Text="Ostatnie rezerwacje" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Lista najnowszych rezerwacji w systemie"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,0,0,10"/>

                                    <DataGrid ItemsSource="{Binding Reservations}"
                                              SelectedItem="{Binding SelectedReservation}"
                                              MinHeight="205">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Gość" Binding="{Binding Guest.FullName}" Width="2*"/>
                                            <DataGridTextColumn Header="Pokój" Binding="{Binding Room.Number}" Width="*"/>
                                            <DataGridTextColumn Header="Od" Binding="{Binding CheckInDate, StringFormat={}{0:dd.MM.yyyy}}" Width="*"/>
                                            <DataGridTextColumn Header="Do" Binding="{Binding CheckOutDate, StringFormat={}{0:dd.MM.yyyy}}" Width="*"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                            <DataGridTextColumn Header="Cena" Binding="{Binding TotalPrice, StringFormat={}{0:C}}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Grid.Column="1" MinHeight="280">
                                <StackPanel>
                                    <TextBlock Text="Szybki podgląd" Style="{StaticResource SectionTitleStyle}"/>

                                    <Border Background="#EFF6FF" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Dzisiejsze meldunki" Style="{StaticResource MutedTextStyle}"/>
                                            <TextBlock Text="{Binding TodayCheckInsCount}" FontSize="30" FontWeight="Bold" Foreground="#2563EB"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#F0FDF4" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Zameldowani goście" Style="{StaticResource MutedTextStyle}"/>
                                            <TextBlock Text="{Binding CheckedInReservationsCount}" FontSize="30" FontWeight="Bold" Foreground="#16A34A"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF7ED" CornerRadius="10" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Wartość rezerwacji" Style="{StaticResource MutedTextStyle}"/>
                                            <TextBlock Text="{Binding ReservationPotentialValue, StringFormat={}{0:C}}" FontSize="24" FontWeight="Bold" Foreground="#EA580C"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Goście">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                        <DataGrid ItemsSource="{Binding Guests}" SelectedItem="{Binding SelectedGuest}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                                <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="*"/>
                                <DataGridTextColumn Header="Dokument" Binding="{Binding DocumentNumber}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dodaj gościa" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Imię" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewGuestFirstName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Nazwisko" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewGuestLastName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Email" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewGuestEmail, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Telefon" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewGuestPhone, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Numer dokumentu" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewGuestDocument, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Dodaj gościa" Command="{Binding AddGuestCommand}" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Usuń zaznaczonego gościa" Command="{Binding DeleteGuestCommand}" Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Pokoje">
                <Border Style="{StaticResource CardStyle}">
                    <DataGrid ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Numer" Binding="{Binding Number}" Width="*"/>
                            <DataGridTextColumn Header="Piętro" Binding="{Binding Floor}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            <DataGridTextColumn Header="Typ pokoju" Binding="{Binding RoomType.Name}" Width="2*"/>
                            <DataGridTextColumn Header="Cena za noc" Binding="{Binding RoomType.PricePerNight, StringFormat={}{0:C}}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Rezerwacje">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                        <DataGrid ItemsSource="{Binding Reservations}" SelectedItem="{Binding SelectedReservation}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Gość" Binding="{Binding Guest.FullName}" Width="2*"/>
                                <DataGridTextColumn Header="Pokój" Binding="{Binding Room.Number}" Width="*"/>
                                <DataGridTextColumn Header="Od" Binding="{Binding CheckInDate, StringFormat={}{0:dd.MM.yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="Do" Binding="{Binding CheckOutDate, StringFormat={}{0:dd.MM.yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                <DataGridTextColumn Header="Cena" Binding="{Binding TotalPrice, StringFormat={}{0:C}}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dodaj rezerwację" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Gość" Style="{StaticResource MutedTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Guests}" SelectedItem="{Binding SelectedGuest}" DisplayMemberPath="FullName"/>
                            <TextBlock Text="Pokój" Style="{StaticResource MutedTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}" DisplayMemberPath="Number"/>
                            <TextBlock Text="Pracownik" Style="{StaticResource MutedTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" DisplayMemberPath="FullName"/>
                            <TextBlock Text="Data od" Style="{StaticResource MutedTextStyle}"/>
                            <DatePicker SelectedDate="{Binding CheckInDate}"/>
                            <TextBlock Text="Data do" Style="{StaticResource MutedTextStyle}"/>
                            <DatePicker SelectedDate="{Binding CheckOutDate}"/>
                            <Button Content="Sprawdź dostępność" Command="{Binding CheckAvailabilityCommand}" Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Dodaj rezerwację" Command="{Binding AddReservationCommand}" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Usuń zaznaczoną rezerwację" Command="{Binding DeleteReservationCommand}" Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Płatności">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                        <DataGrid ItemsSource="{Binding Payments}" SelectedItem="{Binding SelectedPayment}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Rezerwacja" Binding="{Binding Reservation.Id}" Width="*"/>
                                <DataGridTextColumn Header="Gość" Binding="{Binding Reservation.Guest.FullName}" Width="2*"/>
                                <DataGridTextColumn Header="Kwota" Binding="{Binding Amount, StringFormat={}{0:C}}" Width="*"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding PaidAt, StringFormat={}{0:dd.MM.yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="Metoda" Binding="{Binding Method}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dodaj płatność" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Rezerwacja" Style="{StaticResource MutedTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Reservations}" SelectedItem="{Binding SelectedReservation}" DisplayMemberPath="Id"/>
                            <TextBlock Text="Kwota" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewPaymentAmount, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Dodaj płatność" Command="{Binding AddPaymentCommand}" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Usuń zaznaczoną płatność" Command="{Binding DeletePaymentCommand}" Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Pracownicy">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                        <DataGrid ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                                <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>
                                <DataGridTextColumn Header="Stanowisko" Binding="{Binding Position}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dodaj pracownika" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Imię" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewEmployeeFirstName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Nazwisko" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding NewEmployeeLastName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Stanowisko" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding NewEmployeePosition, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Dodaj pracownika" Command="{Binding AddEmployeeCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0"/>
                            <Button Content="Wyczyść formularz" Command="{Binding ClearEmployeeFormCommand}" Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Usuń zaznaczonego pracownika" Command="{Binding DeleteEmployeeCommand}" Style="{StaticResource DangerButton}" Margin="0,18,0,0"/>
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="10" Margin="0,14,0,0">
                                <TextBlock Text="Aby usunąć pracownika, najpierw zaznacz go na liście."
                                           TextWrapping="Wrap"
                                           Style="{StaticResource MutedTextStyle}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Usługi">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                        <StackPanel>
                            <TextBlock Text="Oferta usług dodatkowych" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Kliknij usługę na liście, aby przenieść ją do formularza i edytować."
                                       Style="{StaticResource MutedTextStyle}" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding Services}" SelectedItem="{Binding SelectedService}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="2*"/>
                                    <DataGridTextColumn Header="Cena" Binding="{Binding Price, StringFormat={}{0:C}}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dodaj lub edytuj usługę" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Nazwa usługi" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewServiceName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Cena" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding NewServicePrice, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Zapisz usługę" Command="{Binding SaveServiceCommand}" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Wyczyść formularz" Command="{Binding ClearServiceFormCommand}" Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Usuń zaznaczoną usługę" Command="{Binding DeleteServiceCommand}" Style="{StaticResource DangerButton}"/>
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="12" Margin="0,18,0,0">
                                <TextBlock Text="Po zaznaczeniu usługi z listy formularz działa jako edycja. Jeżeli nic nie jest zaznaczone, system dodaje nową usługę."
                                           TextWrapping="Wrap"
                                           Style="{StaticResource MutedTextStyle}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
